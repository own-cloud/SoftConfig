# Function to quickly jump up a specified number of levels in the directory
up() {
    local levels=${1:-1}  # Default to moving up one level if no argument is provided
    local path=""
    for ((i=1; i<=levels; i++)); do
        path="../$path"
    done
    cd "$path"
}



# [Quick Start | Yazi](https://yazi-rs.github.io/docs/quick-start)
function y() {
	local tmp="$(mktemp -t "yazi-cwd.XXXXXX")" cwd
	command yazi "$@" --cwd-file="$tmp"
	IFS= read -r -d '' cwd < "$tmp"
	[ "$cwd" != "$PWD" ] && [ -d "$cwd" ] && builtin cd -- "$cwd"
	command rm -f -- "$tmp"
}

alias n='y'

