;[user]
 # for local, use: git config user.name "xxx" && git config user.email "yyy"
;	email = xxx
;	name = yyy
[include]
    path = ~/.gitconfig.local
[push]
	default = simple
[alias]
    s = status
    st = stash
    d = diff
    ci = commit
    co = checkout
    br = branch
    gr = grep -I -n
    fo = fetch origin
    cd = checkout origin/develop
    rc = rebase --continue
    diffc = diff --cached 
    stat = log --stat
    unstage = reset HEAD --
    uncommit = reset --soft HEAD~ # undo last commit (redo: -c ORIG_HEAD)
    last = log -1 HEAD
    pick= cherry-pick
    lg1 = log --graph --abbrev-commit --decorate --date=relative --format=format:'%C(bold blue)%h%C(reset) - %C(bold green)(%ar)%C(reset) %C(white)%s%C(reset) %C(dim white)- %an%C(reset)%C(bold yellow)%d%C(reset)' --all
    lg2 = log --graph --abbrev-commit --decorate --format=format:'%C(bold blue)%h%C(reset) - %C(bold cyan)%aD%C(reset) %C(bold green)(%ar)%C(reset)%C(bold yellow)%d%C(reset)%n''          %C(white)%s%C(reset) %C(dim white)- %an%C(reset)' --all
    lg3 = log --graph --abbrev-commit --decorate --date=relative --all
    lg4 = log --graph --oneline --decorate --date=relative --all
    l = log --pretty=colored
    wc = whatchanged
    mt = mergetool
    shallow-clone = clone --depth 1
    pl = pull
    ps = push
    c = commit
    f = fetch
    rb = rebase
    a = add
    bi = bisect
    cl = clone
    i = init
    h = help
    t = tag
    sh = show
    rs = reset
    m = merge
    g = grep
	change-commits = "!f() { VAR=$1; OLD=$2; NEW=$3; shift 3; git filter-branch --env-filter \"if [[ \\\"$`echo $VAR`\\\" = '$OLD' ]]; then export $VAR='$NEW'; fi\" $@; }; f"
