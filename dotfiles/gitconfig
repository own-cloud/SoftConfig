	; tool = meld
[mergetool "meld"]
; comment out this line if you want to use 3-way merge
    cmd = meld $REMOTE $LOCAL -o $MERGED
    meld = trustExitCode

[guitool "gvim"]
	cmd = gvim $FILENAME
	noconsole = yes
	needsfile = yes
[guitool "trimTail"]
	cmd = trimTail $FILENAME
	noconsole = yes
	needsfile = yes
[guitool "Recent log"]
	cmd = git log --oneline -n 10
[pretty]
  colored = format:%Cred%h%Creset %s %Cgreen(%cr) %C(bold blue)%an%Creset
;[core]
;	autocrlf = input
;	quotepath = off
[difftool "sourcetree"]
	cmd = opendiff \"$LOCAL\" \"$REMOTE\"
	path = 
[mergetool "sourcetree"]
	cmd = /Applications/Sourcetree.app/Contents/Resources/opendiff-w.sh \"$LOCAL\" \"$REMOTE\" -ancestor \"$BASE\" -merge \"$MERGED\"
	trustExitCode = true
[gui]
	encoding = utf-8
	fontui = -family \"Noto Sans CJK SC\" -size 12 -weight normal -slant roman -underline 0 -overstrike 0
	fontdiff = -family \"Noto Sans CJK SC\" -size 12 -weight normal -slant roman -underline 0 -overstrike 0
	fonttabular = -family \"Noto Sans CJK SC\" -size 12 -weight normal -slant roman -underline 0 -overstrike 0
#[commit]
    #template = /Users/ross/.gitmessage
[icdiff]
	options = --highlight --line-numbers
[credential]
	helper = store
[core]
	quotepath = false
	excludesfile = /home/ross/.gitignore_global
    # ref: https://www.josean.com/posts/7-amazing-cli-tools
    # need to install git-delta: sudo apt install git-delta
    pager = delta
	editor = vim
	autocrlf = false

[interactive]
    diffFilter = delta --color-only

[delta]
    navigate = true    # use n and N to move between diff sections
    side-by-side = true

    # delta detects terminal colors automatically; set one of these to disable auto-detection
    # dark = true
    # light = true

[merge]
    conflictstyle = diff3

[diff]
    colorMoved = default

[i18n]
	commitencoding = UTF-8
	logoutputencoding = UTF-8
[filter "lfs"]
	required = true
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
[init]
	defaultBranch = main
