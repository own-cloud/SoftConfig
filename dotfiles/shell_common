# Change directory in WSL using a Windows-style path (e.g. copied from Explorer).
wcd() {
  local winpath="$1"
  if [[ -z "$winpath" ]]; then
    echo "Usage: wcd 'C:\\Users\\...\\Folder'" >&2
    return 2
  fi

  # Convert Windows path -> WSL path (handles spaces, drive letters, etc.)
  local wslpath
  wslpath="$(wslpath -u "$winpath")" || return $?

  cd "$wslpath" || return $?
}


# wcd() {
