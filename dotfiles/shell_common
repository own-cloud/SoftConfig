open() {
  [ $# -eq 0 ] && explorer.exe . && return

  for arg in "$@"; do
    [ -e "$arg" ] || { echo "Not found: $arg" >&2; return 1; }

    local abs win
    abs="$(realpath "$arg")" || return $?
    win="$(wslpath -w "$abs")" || return $?

    if [ -d "$arg" ]; then
      explorer.exe "$win"
    else
      explorer.exe "$win"              # or: explorer.exe /select,"$win"
    fi
  done
}

