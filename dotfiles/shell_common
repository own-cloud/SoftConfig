# 0 - (success) is number, 1 - (failure) not a number
# usage: is_number xx && do_sth_for_number
is_number() {
  case $1 in
    ''|*[!0-9]*) return 1 ;; # not a number
    *) return 0 ;; # is a number
  esac
}

add_to_path() {
  for var in "$@"
  do
    [ -d "$1" ] && [ -d "$1/bin" ] && export PATH=$PATH:$1/bin
  done
}

source_if_exists() {
  [ -f "$1" ] && . "$1"
}

# used as: if [ $(isMac) -eq 1 ]; then
isMac() {
    OSNAME=`uname`
    if [[ $OSNAME == 'Darwin' ]]; then
      echo 1
    else
      echo 0
    fi
}

